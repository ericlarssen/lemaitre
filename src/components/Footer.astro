---
import site from "../data/site.json";
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<footer class="bg-forest-dark text-cream-dark">
  <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Business info -->
    <div>
      <h3 class="font-heading text-lg text-white mb-1">{site.name}</h3>
      <span class="heading-accent mb-4"></span>
      <address class="not-italic text-sm leading-relaxed">
        {site.address.street}<br />
        {site.address.city}, {site.address.state} {site.address.zip}<br />
        <a href={`tel:${site.phone}`} class="hover:text-white transition-colors">{site.phone}</a>
      </address>
    </div>

    <!-- Hours -->
    <div>
      <h3 class="font-heading text-lg text-white mb-1">Hours</h3>
      <span class="heading-accent mb-4"></span>
      <ul class="text-sm space-y-1">
        {site.hours.map(({ days, time }) => (
          <li class="flex justify-between max-w-48">
            <span>{days}</span>
            <span>{time}</span>
          </li>
        ))}
      </ul>
      <p class="text-xs mt-2 italic">{site.hoursNote}</p>
    </div>

    <!-- Quick links -->
    <div>
      <h3 class="font-heading text-lg text-white mb-1">Quick Links</h3>
      <span class="heading-accent mb-4"></span>
      <ul class="text-sm space-y-1">
        <li><a href={base} class="hover:text-white transition-colors">Home</a></li>
        <li><a href={`${base}services`} class="hover:text-white transition-colors">Services</a></li>
        <li><a href={`${base}about`} class="hover:text-white transition-colors">About</a></li>
        <li><a href={`${base}contact`} class="hover:text-white transition-colors">Contact</a></li>
        <li class="pt-2"><a href={`${base}privacy`} class="hover:text-white transition-colors">Privacy Policy</a></li>
        <li><a href={`${base}terms`} class="hover:text-white transition-colors">Terms & Conditions</a></li>
        <li><a href={`${base}refund`} class="hover:text-white transition-colors">Warranty & Refunds</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-forest-light text-center text-xs py-4 text-warm-gray-light">
    &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
  </div>
</footer>
