---
import site from "../data/site.json";

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const navLinks = [
  { href: `${base}`, label: "Home" },
  { href: `${base}services`, label: "Services" },
  { href: `${base}about`, label: "About" },
  { href: `${base}contact`, label: "Contact" },
];
---

<header class="bg-ink text-paper border-b border-steel-light/60">
  <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href={base} class="block shrink-0 logo-reveal">
      <img src={`${base}images/logo.svg`} alt={site.name} class="h-14 md:h-16 brightness-0 invert" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      <ul class="flex gap-7 font-display font-bold uppercase text-sm tracking-wide">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "py-1 border-b-2 transition-colors",
                currentPath === (href.replace(/\/$/, '') || '/')
                  ? "border-signal text-white"
                  : "border-transparent text-ash hover:text-white hover:border-signal-dark",
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <span class="w-px h-6 bg-steel-light"></span>
      <a
        href={`tel:${site.phone}`}
        class="font-mono text-sm text-ash hover:text-signal-light transition-colors"
      >
        {site.phone}
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-ash hover:text-white"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav -->
  <ul id="mobile-menu" class="hidden md:hidden px-4 pb-4 space-y-1 font-display font-bold uppercase text-sm tracking-wide">
    {navLinks.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class:list={[
            "block py-2 px-3 transition-colors",
            currentPath === (href.replace(/\/$/, '') || '/')
              ? "bg-steel text-white"
              : "text-ash hover:bg-steel hover:text-white",
          ]}
        >
          {label}
        </a>
      </li>
    ))}
    <li class="border-t border-steel-light pt-2 mt-2">
      <a href={`tel:${site.phone}`} class="block py-2 px-3 font-mono normal-case text-ash hover:text-white transition-colors">
        {site.phone}
      </a>
    </li>
  </ul>
</header>

<style>
  .logo-reveal {
    animation: logo-in 0.7s cubic-bezier(0.16, 0.84, 0.44, 1) both;
  }

  @keyframes logo-in {
    from {
      opacity: 0;
      transform: translateX(-6px);
      clip-path: inset(0 100% 0 0);
    }
    to {
      opacity: 1;
      transform: translateX(0);
      clip-path: inset(0 0 0 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-reveal {
      animation: none;
    }
  }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const isHidden = menu?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", String(!isHidden));
  });
</script>
