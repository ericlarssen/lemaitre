---
import site from "../data/site.json";

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const navLinks = [
  { href: `${base}`, label: "Home" },
  { href: `${base}services`, label: "Services" },
  { href: `${base}about`, label: "About" },
  { href: `${base}contact`, label: "Contact" },
];
---

<header class="bg-forest text-cream">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href={base} class="block">
      <img src={`${base}images/logo.svg`} alt={site.name} class="h-18 -mt-2 -mb-6 brightness-0 invert" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6 text-sm font-medium">
      <ul class="flex gap-6">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "py-1 border-b-2 transition-colors",
                currentPath === (href.replace(/\/$/, '') || '/')
                  ? "border-rust text-white"
                  : "border-transparent text-cream-dark hover:text-white hover:border-rust-light",
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <span class="w-px h-5 bg-forest-light"></span>
      <a href={`tel:${site.phone}`} class="text-cream-dark hover:text-white transition-colors">
        {site.phone}
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-cream-dark hover:text-white"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav -->
  <ul id="mobile-menu" class="hidden md:hidden px-4 pb-4 space-y-2 text-sm font-medium">
    {navLinks.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class:list={[
            "block py-2 px-3 rounded transition-colors",
            currentPath === (href.replace(/\/$/, '') || '/')
              ? "bg-forest-light text-white"
              : "text-cream-dark hover:bg-forest-light hover:text-white",
          ]}
        >
          {label}
        </a>
      </li>
    ))}
    <li class="border-t border-forest-light pt-2">
      <a href={`tel:${site.phone}`} class="block py-2 px-3 text-cream-dark hover:text-white transition-colors">
        {site.phone}
      </a>
    </li>
  </ul>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
