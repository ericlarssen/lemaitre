---
import Layout from "../layouts/Layout.astro";
import site from "../data/site.json";
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title={`Contact — ${site.name}`}>
  <!-- Hero banner -->
  <section class="relative py-20 px-4 overflow-hidden">
    <div class="absolute inset-0">
      <img src={`${base}images/mechanic-2.png`} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-forest/80"></div>
    </div>
    <div class="relative max-w-5xl mx-auto text-center">
      <h1 class="text-4xl font-heading font-bold text-white mb-4">Contact Us</h1>
      <p class="text-cream-dark text-lg">
        Have a question or want to schedule service? Reach out and we'll get back to you.
      </p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-5xl mx-auto">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <!-- Contact form -->
        <form
          action="#"
          method="POST"
          class="space-y-5"
        >
          <div>
            <label for="name" class="block text-sm font-medium mb-1">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full border border-cream-dark rounded px-4 py-2 bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-forest"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border border-cream-dark rounded px-4 py-2 bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-forest"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium mb-1">Phone <span class="text-warm-gray-light">(optional)</span></label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full border border-cream-dark rounded px-4 py-2 bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-forest"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full border border-cream-dark rounded px-4 py-2 bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-forest resize-y"
            ></textarea>
          </div>
          <button
            type="submit"
            class="bg-rust hover:bg-rust-light text-white font-semibold py-3 px-8 rounded transition-colors w-full sm:w-auto"
          >
            Send Message
          </button>
        </form>

        <!-- Contact info + map -->
        <div class="space-y-6">
          <div>
            <h2 class="font-heading text-xl font-semibold mb-3">Get in Touch</h2>
            <ul class="space-y-2 text-sm text-warm-gray">
              <li>
                <span class="font-medium text-charcoal">Phone:</span>
                <a href={`tel:${site.phone}`} class="hover:text-forest transition-colors">{site.phone}</a>
              </li>
              <li>
                <span class="font-medium text-charcoal">Email:</span>
                <a href={`mailto:${site.email}`} class="hover:text-forest transition-colors">{site.email}</a>
              </li>
              <li>
                <span class="font-medium text-charcoal">Address:</span>
                {site.address.street}, {site.address.city}, {site.address.state} {site.address.zip}
              </li>
            </ul>
          </div>

          <div>
            <h2 class="font-heading text-xl font-semibold mb-3">Hours</h2>
            <ul class="space-y-1 text-sm">
              {site.hours.map(({ days, time }) => (
                <li class="flex justify-between max-w-64">
                  <span class="font-medium">{days}</span>
                  <span class="text-warm-gray">{time}</span>
                </li>
              ))}
            </ul>
            <p class="text-warm-gray text-xs mt-3 italic">{site.hoursNote}</p>
            <p class="text-warm-gray text-xs mt-1 italic">After-hours key drop available.</p>
          </div>

          <div class="rounded-lg overflow-hidden shadow-md h-52">
            <iframe
              src={site.googleMapsEmbedUrl}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Map to Le Maitre's Auto and Repair"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
