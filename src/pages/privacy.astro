---
import Layout from "../layouts/Layout.astro";
import site from "../data/site.json";
---

<Layout title={`Privacy Policy — ${site.name}`}>
  <section class="pt-12 pb-20 px-4">
    <div class="max-w-3xl mx-auto">
      <span class="section-label">Legal</span>
      <h1 class="text-3xl md:text-4xl font-display font-bold mb-2">Privacy Policy</h1>
      <span class="heading-accent mb-8"></span>
      <p class="text-ash-dark text-sm mb-10">Last updated: February 2026</p>

      <div class="space-y-8 text-ash-dark leading-relaxed">
        <div>
          <h2 class="font-display text-xl font-semibold text-ink mb-3">What We Collect</h2>
          <p>
            When you use our contact form or reach out by phone or email, we may collect your
            name, phone number, email address, and details about your vehicle or service needs.
            We only collect what you voluntarily provide.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink mb-3">How We Use It</h2>
          <p>
            We use your information to respond to your inquiries, schedule appointments,
            provide repair services, and communicate with you about your vehicle. We do not
            use your information for marketing unless you ask us to.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink mb-3">Third-Party Services</h2>
          <p>
            Our website uses Google Maps to display our location. Google may collect usage
            data through this embed according to their own privacy policy. We do not sell,
            rent, or share your personal information with any other third parties.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink mb-3">Data Security</h2>
          <p>
            We take reasonable steps to protect your information. However, no method of
            transmission over the internet is 100% secure, and we cannot guarantee
            absolute security.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink mb-3">Your Rights</h2>
          <p>
            You may request to see, update, or delete any personal information we have on
            file. Just contact us and we'll take care of it.
          </p>
        </div>

        <div>
          <h2 class="font-display text-xl font-semibold text-ink mb-3">Contact Us</h2>
          <p>
            If you have questions about this policy, reach out anytime:
          </p>
          <address class="not-italic mt-2">
            {site.name}<br />
            {site.address.street}<br />
            {site.address.city}, {site.address.state} {site.address.zip}<br />
            <a href={`tel:${site.phone}`} class="text-signal hover:text-signal-dark transition-colors">{site.phone}</a><br />
            <a href={`mailto:${site.email}`} class="text-signal hover:text-signal-dark transition-colors">{site.email}</a>
          </address>
        </div>
      </div>
    </div>
  </section>
</Layout>
