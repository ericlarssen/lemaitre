---
import Layout from "../layouts/Layout.astro";
import site from "../data/site.json";
---

<Layout title={`${site.name} — Honest Auto Repair You Can Trust`}>
  <!-- Hero -->
  <section class="bg-forest text-cream py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">
        Honest Auto Repair<br />You Can Count On
      </h1>
      <p class="text-cream-dark text-lg md:text-xl mb-8 max-w-2xl mx-auto">
        Family-owned and operated, serving our community with reliable auto repair and
        straightforward service — no surprises, no runarounds.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-block bg-rust hover:bg-rust-light text-white font-semibold py-3 px-8 rounded transition-colors"
        >
          Get in Touch
        </a>
        <a
          href={`tel:${site.phone}`}
          class="inline-block border-2 border-cream-dark text-cream-dark hover:bg-cream hover:text-forest font-semibold py-3 px-8 rounded transition-colors"
        >
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Services preview -->
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-heading font-bold text-center mb-10">What We Do</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {site.services.map(({ title, description }) => (
          <div class="bg-white rounded-lg p-6 shadow-sm border border-cream-dark/30 hover:shadow-md transition-shadow">
            <h3 class="font-heading text-xl font-semibold text-forest mb-2">{title}</h3>
            <p class="text-warm-gray text-sm leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/services" class="text-rust hover:text-rust-dark font-medium transition-colors">
          View all services &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Hours & Location -->
  <section class="bg-cream-dark py-16 px-4">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
      <div>
        <h2 class="text-3xl font-heading font-bold mb-6">Hours & Location</h2>
        <address class="not-italic text-warm-gray mb-4">
          {site.address.street}<br />
          {site.address.city}, {site.address.state} {site.address.zip}
        </address>
        <ul class="space-y-1 text-sm">
          {site.hours.map(({ day, open, close }) => (
            <li class="flex justify-between max-w-64">
              <span class="font-medium">{day}</span>
              <span class="text-warm-gray">{close ? `${open} – ${close}` : open}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-lg overflow-hidden shadow-md h-72">
        <iframe
          src={site.googleMapsEmbedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Map to Le Maitre's Auto and Repair"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
