---
import Layout from "../layouts/Layout.astro";
import site from "../data/site.json";
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title={`${site.name} — Local Auto Repair in Eldridge, Iowa`}>
  <!-- Hero -->
  <section class="relative text-cream py-24 md:py-36 px-4 overflow-hidden">
    <div class="absolute inset-0">
      <img src={`${base}images/ribbon-cutting.png`} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-forest/70"></div>
    </div>
    <div class="relative max-w-4xl mx-auto text-center">
      <h1 class="font-heading font-bold text-3xl md:text-5xl lg:text-6xl text-white leading-tight mb-6">
        Where Passion<br class="hidden sm:block" /> Meets Precision
      </h1>
      <p class="text-cream/80 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
        Honest service, expert care, and hometown pride in every repair.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-4 justify-center">
        <a
          href={`${base}contact`}
          class="inline-block bg-rust hover:bg-rust-light text-white font-semibold py-3 px-8 rounded transition-colors"
        >
          Get in Touch
        </a>
        <span class="text-cream-dark/60 text-sm">
          or call <a href={`tel:${site.phone}`} class="underline hover:text-white transition-colors">{site.phone}</a>
        </span>
      </div>
    </div>
  </section>

  <!-- Services preview -->
  <section class="bg-cream-dark pt-20 pb-24 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <span class="section-label">What We Do</span>
        <h2 class="text-2xl md:text-3xl font-heading font-bold">Our Services</h2>
        <span class="heading-accent heading-accent--center"></span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {site.services.slice(0, 4).map(({ title, image }) => (
          <a href={`${base}services`} class="group">
            <div class="h-40 overflow-hidden rounded-lg">
              <img src={`${base}${image.slice(1)}`} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            </div>
            <h3 class="font-heading text-lg font-semibold text-forest group-hover:text-rust transition-colors mt-3">{title}</h3>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={`${base}services`} class="section-label hover:text-rust-dark transition-colors">
          View all services &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Visit Us -->
  <section class="pt-16 pb-20 px-4 border-t border-cream-dark">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <span class="section-label">Come See Us</span>
        <h2 class="text-2xl md:text-3xl font-heading font-bold">Visit Us</h2>
        <span class="heading-accent heading-accent--center"></span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
        <div>
          <h3 class="font-heading text-xl font-semibold mb-4">Hours & Location</h3>
          <address class="not-italic text-warm-gray mb-4">
            {site.address.street}<br />
            {site.address.city}, {site.address.state} {site.address.zip}
          </address>
          <p class="text-warm-gray mb-1">
            <span class="font-medium text-charcoal">Phone:</span>
            <a href={`tel:${site.phone}`} class="hover:text-forest transition-colors">{site.phone}</a>
          </p>
          <p class="text-warm-gray mb-6">
            <span class="font-medium text-charcoal">Email:</span>
            <a href={`mailto:${site.email}`} class="hover:text-forest transition-colors">{site.email}</a>
          </p>
          <ul class="space-y-1 text-sm">
            {site.hours.map(({ days, time }) => (
              <li class="flex justify-between max-w-64">
                <span class="font-medium">{days}</span>
                <span class="text-warm-gray">{time}</span>
              </li>
            ))}
          </ul>
          <p class="text-warm-gray text-xs mt-3 italic">{site.hoursNote}</p>
          <p class="text-warm-gray text-xs mt-1 italic">After-hours key drop available.</p>
        </div>
        <div class="rounded-lg overflow-hidden shadow-md h-72">
          <iframe
            src={site.googleMapsEmbedUrl}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Map to LeMaitre's Auto and Repair"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>
