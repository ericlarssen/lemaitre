---
import Layout from "../layouts/Layout.astro";
import site from "../data/site.json";
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title={`${site.name} — Local Auto Repair in Eldridge, Iowa`}>
  <!-- Hero -->
  <section class="bg-ink text-paper relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-8 items-center relative">
      <div class="py-16 md:py-24">
        <span class="eyebrow mb-5">Eldridge, Iowa</span>
        <h1 class="font-display font-black text-4xl md:text-5xl lg:text-6xl text-white leading-[0.95] mb-6">
          We fix it right.<br />We tell you straight.
        </h1>
        <p class="text-ash text-lg mb-8 leading-relaxed max-w-md normal-case font-body">
          Honest repair from a shop that still knows its neighbors by name.
        </p>
        <div class="flex flex-col sm:flex-row items-start gap-5">
          <a href={`${base}contact`} class="btn-signal">
            Book a Repair
          </a>
          <span class="text-ash text-sm py-3 font-mono">
            or call <a href={`tel:${site.phone}`} class="text-white hover:text-signal-light transition-colors">{site.phone}</a>
          </span>
        </div>
      </div>
      <div class="hidden md:block relative">
        <div class="absolute -inset-4 border border-steel-light/70 -z-10"></div>
        <img src={`${base}images/corey-2.png`} alt="Corey LeMaitre, owner, at the shop" class="w-full h-auto photo-warm" />
      </div>
    </div>
  </section>

  <!-- Services preview -->
  <section class="bg-concrete pt-20 pb-24 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <span class="eyebrow">What We Work On</span>
        <h2 class="text-2xl md:text-3xl font-display font-black text-ink mt-2">Services</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {site.services.slice(0, 4).map(({ title, image }) => (
          <a href={`${base}services`} class="group block bg-steel">
            <div class="relative h-40 photo-duotone">
              <img src={`${base}${image.slice(1)}`} alt={title} class="group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <h3 class="font-display text-base font-bold text-white group-hover:text-signal-light transition-colors px-4 py-4 tracking-wide">{title}</h3>
          </a>
        ))}
      </div>
      <div class="mt-10">
        <a href={`${base}services`} class="eyebrow hover:text-signal-dark transition-colors">
          View all services &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Visit Us -->
  <section class="pt-16 pb-20 px-4 bg-paper">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <span class="eyebrow">Come See Us</span>
        <h2 class="text-2xl md:text-3xl font-display font-black text-ink mt-2">Visit Us</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
        <div class="font-mono text-sm">
          <h3 class="font-display text-xl font-bold mb-4 text-ink normal-case tracking-normal">Hours &amp; Location</h3>
          <address class="not-italic text-ash-dark mb-4 leading-relaxed">
            {site.address.street}<br />
            {site.address.city}, {site.address.state} {site.address.zip}
          </address>
          <p class="text-ash-dark mb-1">
            <span class="text-ink">Phone:</span>
            <a href={`tel:${site.phone}`} class="hover:text-signal transition-colors">{site.phone}</a>
          </p>
          <p class="text-ash-dark mb-6">
            <span class="text-ink">Email:</span>
            <a href={`mailto:${site.email}`} class="hover:text-signal transition-colors">{site.email}</a>
          </p>
          <ul class="space-y-1">
            {site.hours.map(({ days, time }) => (
              <li class="flex justify-between max-w-64 border-b border-concrete py-1">
                <span class="text-ink">{days}</span>
                <span class="text-ash-dark">{time}</span>
              </li>
            ))}
          </ul>
          <p class="text-ash text-xs mt-3">{site.hoursNote}</p>
          <p class="text-ash text-xs mt-1">After-hours key drop available.</p>
        </div>
        <div class="overflow-hidden h-72 border border-concrete">
          <iframe
            src={site.googleMapsEmbedUrl}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Map to LeMaitre's Auto and Repair"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>
