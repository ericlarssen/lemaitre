---
import Layout from "../layouts/Layout.astro";
import site from "../data/site.json";
---

<Layout title={`Services — ${site.name}`}>
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-heading font-bold text-center mb-4">Our Services</h1>
      <p class="text-warm-gray text-center mb-12 max-w-2xl mx-auto">
        We work on most makes and models. Whether it's routine maintenance or a major repair,
        we'll give you an honest assessment and fair price.
      </p>

      <div class="space-y-6">
        {site.services.map(({ title, description }) => (
          <div class="bg-white rounded-lg p-6 shadow-sm border border-cream-dark/30">
            <h2 class="font-heading text-2xl font-semibold text-forest mb-2">{title}</h2>
            <p class="text-warm-gray leading-relaxed">{description}</p>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center bg-forest rounded-lg p-8">
        <h2 class="font-heading text-2xl text-white mb-3">Not sure what you need?</h2>
        <p class="text-cream-dark mb-6">
          No problem. Give us a call or stop by and we'll take a look.
        </p>
        <a
          href="/contact"
          class="inline-block bg-rust hover:bg-rust-light text-white font-semibold py-3 px-8 rounded transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>
