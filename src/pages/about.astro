---
import Layout from "../layouts/Layout.astro";
import site from "../data/site.json";
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title={`About — ${site.name}`}>
  <!-- Our Story -->
  <section class="pt-16 pb-16 px-4 bg-paper">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div class="border border-concrete photo-warm">
          <img src={`${base}images/corey.png`} alt="Corey LeMaitre, owner" />
        </div>
        <div>
          <span class="eyebrow">Our Story</span>
          <h1 class="text-3xl md:text-4xl font-display font-black mt-2 mb-6 text-ink">
            Built on passion.<br />Driven by integrity.
          </h1>
          <div class="space-y-4 text-ash-dark leading-relaxed font-body">
            <p>
              Corey's love for cars started early — in his family garage, taking apart
              engines just to see how they worked. Over the years, that curiosity grew
              into skill, and that skill into a dream: to open his own shop built on
              honesty, hard work, and hometown pride.
            </p>
            <p>
              Born and raised in the North Scott community, Corey grew up here, went
              to school here, and chose to build his business here. His shop sits
              right on the main drag in Eldridge — because he wanted to serve the
              same neighbors he's known his whole life.
            </p>
            <p>
              Whether you're here for routine maintenance or major repairs, LeMaitre's
              Auto and Repair is here to keep you safely on the road.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ribbon cutting + Contact CTA -->
  <section class="bg-concrete py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="border border-ink/10 photo-warm mb-10">
        <img src={`${base}images/ribbon-cutting.png`} alt="Grand opening ribbon cutting with the North Scott Chamber of Commerce" />
      </div>
      <div class="text-center">
        <span class="eyebrow justify-center">Let's Work Together</span>
        <h2 class="text-2xl md:text-3xl font-display font-black mt-2 mb-6 text-ink">Bring Your Vehicle In</h2>
        <p class="text-ash-dark mb-6 font-body">
          Bring your vehicle to a shop you can trust.
        </p>
        <div class="space-y-1 text-ash-dark mb-8 font-mono text-sm">
          <address class="not-italic">
            {site.address.street}, {site.address.city}, {site.address.state} {site.address.zip}
          </address>
          <p>
            <a href={`mailto:${site.email}`} class="hover:text-signal transition-colors">{site.email}</a>
            &nbsp;&middot;&nbsp;
            <a href={`tel:${site.phone}`} class="hover:text-signal transition-colors">{site.phone}</a>
          </p>
        </div>
        <a href={`${base}contact`} class="inline-flex items-center justify-center gap-2 bg-ink text-white font-display font-bold uppercase tracking-wide px-8 py-3 hover:bg-signal transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>
